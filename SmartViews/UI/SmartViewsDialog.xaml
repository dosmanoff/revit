<Window x:Class="SmartViews.UI.SmartViewsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartViews — Configure Views"
        Width="860" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,4,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Preset -->
            <RowDefinition Height="Auto"/>   <!-- Config folder -->
            <RowDefinition Height="Auto"/>   <!-- Crop offset -->
            <RowDefinition Height="Auto"/>   <!-- Duplicates -->
            <RowDefinition Height="Auto"/>   <!-- View kinds header -->
            <RowDefinition Height="*"/>      <!-- View kinds grid -->
            <RowDefinition Height="Auto"/>   <!-- Plan view range -->
            <RowDefinition Height="Auto"/>   <!-- OK / Cancel -->
        </Grid.RowDefinitions>

        <!-- ── Preset ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Preset:"/>
            <ComboBox Grid.Column="1" x:Name="CmbPreset"
                      IsEditable="True"
                      ToolTip="Type a name or pick an existing preset"/>
            <Button Grid.Column="2" Content="Load" Click="LoadPreset_Click"
                    ToolTip="Load the selected preset into these settings"/>
            <Button Grid.Column="3" Content="Save" Click="SavePreset_Click"
                    ToolTip="Save current settings as the named preset"/>
        </Grid>

        <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="0,32,0,0"/>

        <!-- ── Config folder ────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Config folder:"/>
            <TextBox Grid.Column="1" x:Name="TxtConfigFolder"
                     LostFocus="TxtConfigFolder_LostFocus"/>
            <Button Grid.Column="2" Content="…" Click="BrowseFolder_Click"/>
        </Grid>

        <!-- ── Crop offsets ─────────────────────────────────────────────── -->
        <GroupBox Grid.Row="2" Header="Crop offsets (ft)" Margin="0,8,0,0" Padding="8,4,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="58"/>
                </Grid.ColumnDefinitions>
                <Label   Grid.Column="0"  Content="Left:"/>
                <TextBox Grid.Column="1"  x:Name="TxtOffLeft"/>
                <Label   Grid.Column="2"  Content="Right:"/>
                <TextBox Grid.Column="3"  x:Name="TxtOffRight"/>
                <Label   Grid.Column="4"  Content="Top:"/>
                <TextBox Grid.Column="5"  x:Name="TxtOffTop"/>
                <Label   Grid.Column="6"  Content="Bottom:"/>
                <TextBox Grid.Column="7"  x:Name="TxtOffBottom"/>
                <Label   Grid.Column="8"  Content="Near:"/>
                <TextBox Grid.Column="9"  x:Name="TxtOffNear"/>
                <Label   Grid.Column="10" Content="Far:"/>
                <TextBox Grid.Column="11" x:Name="TxtOffFar"/>
                <Label   Grid.Column="13" Content="Set all:"
                         HorizontalAlignment="Right" Margin="0,4,6,0"/>
                <TextBox Grid.Column="14" x:Name="TxtOffAll"
                         ToolTip="Type a value and press Tab to copy it to all six fields"
                         LostFocus="TxtOffAll_LostFocus"/>
            </Grid>
        </GroupBox>

        <!-- ── Duplicate handling ───────────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Duplicates:"/>
            <ComboBox Grid.Column="1" x:Name="CmbDuplicates"/>
        </Grid>

        <!-- ── View kinds ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Text="View kinds to create:"
                   Margin="0,12,0,4" FontWeight="SemiBold"/>

        <DataGrid Grid.Row="5"
                  x:Name="GridViewKinds"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  MinHeight="100"
                  MaxHeight="240"
                  Margin="0,0,0,12"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Kind"
                                        SelectedItemBinding="{Binding Kind}"
                                        Width="85"/>
                <DataGridComboBoxColumn Header="Direction"
                                        SelectedItemBinding="{Binding SectionDirection}"
                                        Width="68"/>
                <DataGridCheckBoxColumn Header="All dirs"
                                        Binding="{Binding CreateAllDirections}"
                                        Width="58"/>
                <DataGridCheckBoxColumn Header="Align↗"
                                        Binding="{Binding AlignToElement}"
                                        Width="52"/>
                <DataGridTextColumn Header="Name template  ({Mark} {Direction} {Level} {Type} {Index})"
                                    Binding="{Binding NameTemplate}"
                                    Width="*"/>
                <DataGridTextColumn Header="View family type"
                                    Binding="{Binding ViewFamilyTypeName}"
                                    Width="110"/>
                <DataGridTextColumn Header="Template"
                                    Binding="{Binding ViewTemplateName}"
                                    Width="100"/>
                <DataGridTextColumn Header="Sheet #"
                                    Binding="{Binding SheetNumber}"
                                    Width="72"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Plan view range ──────────────────────────────────────────── -->
        <Border Grid.Row="6" BorderBrush="#ccc" BorderThickness="1"
                CornerRadius="3" Padding="8,6" Margin="0,0,0,12">
            <StackPanel>
                <CheckBox x:Name="ChkPlanRange"
                          Content="Custom plan view range (offsets in ft above host level)"
                          Margin="0,0,0,6"
                          Checked="ChkPlanRange_Changed"
                          Unchecked="ChkPlanRange_Changed"/>
                <StackPanel Orientation="Horizontal" x:Name="PnlPlanRangeFields">
                    <Label Content="Top:"/>
                    <TextBox x:Name="TxtPlanTop"    Width="52" Margin="0,0,12,0"/>
                    <Label Content="Cut:"/>
                    <TextBox x:Name="TxtPlanCut"    Width="52" Margin="0,0,12,0"/>
                    <Label Content="Bottom:"/>
                    <TextBox x:Name="TxtPlanBottom" Width="52" Margin="0,0,12,0"/>
                    <Label Content="View depth:"/>
                    <TextBox x:Name="TxtPlanDepth"  Width="52"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── OK / Cancel ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>
