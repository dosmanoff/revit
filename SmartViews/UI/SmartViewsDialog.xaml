<Window x:Class="SmartViews.UI.SmartViewsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartViews — Configure Views"
        Width="600" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,4,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Preset -->
            <RowDefinition Height="Auto"/>   <!-- Config folder -->
            <RowDefinition Height="Auto"/>   <!-- Crop offset -->
            <RowDefinition Height="Auto"/>   <!-- Duplicates -->
            <RowDefinition Height="Auto"/>   <!-- View kinds header -->
            <RowDefinition Height="*"/>      <!-- View kinds grid -->
            <RowDefinition Height="Auto"/>   <!-- OK / Cancel -->
        </Grid.RowDefinitions>

        <!-- ── Preset ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Preset:"/>
            <ComboBox Grid.Column="1" x:Name="CmbPreset"
                      IsEditable="True"
                      ToolTip="Type a name or pick an existing preset"/>
            <Button Grid.Column="2" Content="Load"  Click="LoadPreset_Click"  ToolTip="Load the selected preset into these settings"/>
            <Button Grid.Column="3" Content="Save"  Click="SavePreset_Click"  ToolTip="Save current settings as the named preset"/>
        </Grid>

        <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="0,32,0,0"/>

        <!-- ── Config folder ────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Config folder:"/>
            <TextBox Grid.Column="1" x:Name="TxtConfigFolder"
                     LostFocus="TxtConfigFolder_LostFocus"/>
            <Button Grid.Column="2" Content="…" Click="BrowseFolder_Click"/>
        </Grid>

        <!-- ── Crop offset ──────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Crop offset (ft):"/>
            <TextBox Grid.Column="1" x:Name="TxtCropOffset"/>
        </Grid>

        <!-- ── Duplicate handling ───────────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Duplicates:"/>
            <ComboBox Grid.Column="1" x:Name="CmbDuplicates"/>
        </Grid>

        <!-- ── View kinds ───────────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Text="View kinds to create:"
                   Margin="0,12,0,4" FontWeight="SemiBold"/>

        <DataGrid Grid.Row="5"
                  x:Name="GridViewKinds"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  MinHeight="100"
                  MaxHeight="260"
                  Margin="0,0,0,12"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Kind"
                                        SelectedItemBinding="{Binding Kind}"
                                        Width="90"/>
                <DataGridComboBoxColumn Header="Direction"
                                        SelectedItemBinding="{Binding SectionDirection}"
                                        Width="72"/>
                <DataGridTextColumn Header="Name template"
                                    Binding="{Binding NameTemplate}"
                                    Width="*"/>
                <DataGridTextColumn Header="View family type"
                                    Binding="{Binding ViewFamilyTypeName}"
                                    Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── OK / Cancel ──────────────────────────────────────────────── -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>
