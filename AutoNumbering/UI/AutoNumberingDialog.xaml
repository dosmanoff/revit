<Window x:Class="AutoNumbering.UI.AutoNumberingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto-Numbering"
        Width="740" Height="580"
        MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,4,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="8,4,8,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Selection -->
            <RowDefinition Height="Auto"/>   <!-- Numbering -->
            <RowDefinition Height="Auto"/>   <!-- Parameters -->
            <RowDefinition Height="*"/>      <!-- Elements grid -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Row 0: Selection -->
        <GroupBox Grid.Row="0" Header="Selection">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Re-select Elements…"
                        Click="ReSelect_Click"
                        ToolTip="Close dialog and pick elements again in the model"/>
                <TextBlock x:Name="TxtSelectionInfo"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </DockPanel>
        </GroupBox>

        <!-- Row 1: Numbering -->
        <GroupBox Grid.Row="1" Header="Numbering">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Prefix:" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtPrefix" Width="100"
                             TextChanged="NumberingParam_Changed"/>
                    <Label Content="Start:"/>
                    <TextBox x:Name="TxtStart" Width="52" Text="1"
                             TextChanged="NumberingParam_Changed"/>
                    <Label Content="Step:"/>
                    <TextBox x:Name="TxtStep" Width="52" Text="1"
                             TextChanged="NumberingParam_Changed"/>
                    <Label Content="Min digits:"/>
                    <TextBox x:Name="TxtDigits" Width="40" Text="1"
                             TextChanged="NumberingParam_Changed"/>
                    <Label Content="Suffix:"/>
                    <TextBox x:Name="TxtSuffix" Width="100"
                             TextChanged="NumberingParam_Changed"/>
                </StackPanel>
                <TextBlock x:Name="TxtPreview"
                           Margin="2,6,0,0"
                           Foreground="#FF888888"
                           FontStyle="Italic"
                           FontSize="11"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 2: Parameters -->
        <GroupBox Grid.Row="2" Header="Parameters">
            <StackPanel Orientation="Horizontal">
                <Label Content="Write to:" Margin="0,0,4,0"
                       ToolTip="Parameter to write the number into (must be a writable text parameter)"/>
                <ComboBox x:Name="CmbTargetParam" Width="180" IsEditable="True"
                          SelectionChanged="TargetParam_SelectionChanged"
                          LostFocus="TargetParam_LostFocus"/>
                <Label Content="Sort by:"
                       ToolTip="Sort elements by this parameter before assigning numbers"/>
                <ComboBox x:Name="CmbSortParam" Width="180" IsEditable="True"
                          SelectionChanged="SortParam_Changed"
                          LostFocus="SortParam_LostFocus"/>
                <ComboBox x:Name="CmbSortDir" Width="100" Margin="4,0,0,0"
                          SelectionChanged="SortParam_Changed">
                    <ComboBoxItem Content="Ascending" IsSelected="True"/>
                    <ComboBoxItem Content="Descending"/>
                </ComboBox>
            </StackPanel>
        </GroupBox>

        <!-- Row 3: Elements DataGrid -->
        <DataGrid Grid.Row="3"
                  x:Name="ElementsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FFF5F5F5"
                  HeadersVisibility="Column"
                  Margin="0,0,0,8"
                  Sorting="ElementsGrid_Sorting">
            <DataGrid.Columns>
                <!-- Include checkbox -->
                <DataGridTemplateColumn Header="✓" Width="32" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsIncluded, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Checked="InclusionChanged"
                                      Unchecked="InclusionChanged"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Family / Type"
                                    Binding="{Binding FamilyType}"
                                    Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="Sort Value"
                                    Binding="{Binding SortKeyValue}"
                                    Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Current Value"
                                    Binding="{Binding CurrentValue}"
                                    Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="New Value"
                                    Binding="{Binding ProposedNumber}"
                                    Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#FF1A6B1A"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" MinWidth="80" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
